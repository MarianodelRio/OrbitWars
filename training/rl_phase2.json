{
  "run_name": "rl_phase2_mixed",
  "run_id": "run_001",
  "device": "auto",
  "seed": 42,
  "total_iterations": 1200,

  "model_config": {
    "Dp": 24, "Df": 16, "Dg": 16,
    "E": 192, "F": 128, "G": 384,
    "max_planets": 50, "max_fleets": 200,
    "n_amount_bins": 8, "n_heads": 8,
    "n_layers": 4, "ffn_hidden": 768,
    "dropout": 0.1, "lstm_bypass": false
  },

  "n_rollout_steps": 8192,
  "steps_per_episode": 500,
  "ppo_epochs": 4,
  "ppo_batch_size": 512,
  "clip_eps": 0.2,
  "value_clip_eps": 0.2,
  "vf_coef": 0.5,
  "max_grad_norm": 0.5,
  "lr": 0.00015,
  "lr_schedule": "cosine",
  "normalize_advantages": true,

  "gamma": 0.997,
  "gae_lambda": 0.95,

  "w_planets": 0.5,
  "w_production": 1.0,
  "w_ships": 0.1,
  "reward_lambda": 0.2,
  "r_terminal_win": 15.0,
  "r_terminal_loss": -15.0,
  "r_terminal_margin_coef": 5.0,
  "r_event_capture_enemy": 0.5,
  "r_event_capture_comet": 0.2,
  "r_event_eliminate_opponent": 1.5,
  "r_event_lose_planet": -0.5,
  "r_explore": 0.0,
  "explore_iterations": 0,

  "entropy_coef_action_type": 0.005,
  "entropy_coef_target": 0.001,
  "entropy_coef_amount": 0.001,

  "self_play_prob": 0.25,
  "heuristic_opponents": [
    "bots.heuristic.baseline:agent_fn",
    "bots.heuristic.sniper:agent_fn",
    "bots.scoring.bot:agent_fn",
    "bots.heuristic.oracle_sniper:agent_fn"
  ],
  "frozen_checkpoint": "runs/rl_phase1_anchored_v2/run_001/checkpoints/rl_last.pt",
  "max_snapshots": 5,
  "snapshot_every": 50,

  "bc_policy_path": "",
  "kl_bc_coef_start": 0.3,
  "kl_bc_coef_end": 0.05,
  "kl_bc_coef_decay_iters": 150,
  "il_data_cache_path": "",
  "il_distill_ratio": 0.0,

  "eval_every": 25,
  "n_eval_matches": 20,
  "eval_opponents": ["heuristic.baseline", "heuristic.sniper", "scoring.bot", "heuristic.oracle_sniper"],
  "save_every": 25,
  "use_amp": true,
  "amp_dtype": "bfloat16",
  "use_compile": true,
  "n_envs": 3
}
